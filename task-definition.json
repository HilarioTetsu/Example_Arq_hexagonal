{
  "family": "activos-task",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "activos-backend-container",
      "image": "000000000000.dkr.ecr.us-east-1.localhost.localstack.cloud:4566/activos-repo:latest",
      "memory": 512,
      "cpu": 256,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080
        }
      ],
      "environment": [
        {"name": "SPRING_PROFILES_ACTIVE", "value": "prod"},
        {"name": "RDS_HOSTNAME", "value": "localhost.localstack.cloud"},
        {"name": "RDS_PORT", "value": "4510"},
        {"name": "RDS_DB_NAME", "value": "activos_db"},
        {"name": "RDS_USERNAME", "value": "db_admin_local"},
        {"name": "RDS_PASSWORD", "value": "super_secret_pass_local"},
        {"name": "SPRING_JPA_HIBERNATE_DDL_AUTO", "value": "update"}
      ]
    }
  ]
}